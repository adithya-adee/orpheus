#!/usr/bin/env bash
# Orpheus — a themed rmpc front-end (blue/white, vim + ncmpcpp keys, YouTube,
# synced lyrics). Pick an alternate palette with ORPHEUS_THEME=<name>:
#   ORPHEUS_THEME=dracula orpheus
set -euo pipefail

DIR="/home/glitchy_moon/github_repo/orpheus"
VERSION="$(cat "$DIR/VERSION" 2>/dev/null || echo '?')"

case "${1:-}" in
  -V|--version) echo "Orpheus $VERSION  ·  $(rmpc version 2>/dev/null || echo rmpc)"; exit 0 ;;
esac

theme_file="$DIR/theme.ron"
if [ -n "${ORPHEUS_THEME:-}" ] && [ -f "$DIR/themes/${ORPHEUS_THEME}.ron" ]; then
  theme_file="$DIR/themes/${ORPHEUS_THEME}.ron"
fi

# Start each session on the chosen theme (Frost by default) so the runtime
# picker/cycle always begins from a known baseline.
mkdir -p "$HOME/.cache"
printf '%s\n' "${ORPHEUS_THEME:-frost}" > "$HOME/.cache/orpheus-theme"

exec rmpc -c "$DIR/config.ron" -t "$theme_file" "$@"
