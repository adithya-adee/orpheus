#!/usr/bin/env bash
# Orpheus — a themed rmpc front-end (vim + ncmpcpp keys, YouTube, synced lyrics).
# Remembers your last theme across launches; default is solarized-dark.
# Force one with:  ORPHEUS_THEME=dracula orpheus
set -euo pipefail

DIR="/home/glitchy_moon/github_repo/orpheus"
VERSION="$(cat "$DIR/VERSION" 2>/dev/null || echo '?')"

case "${1:-}" in
  -V|--version) echo "Orpheus $VERSION  ·  $(rmpc version 2>/dev/null || echo rmpc)"; exit 0 ;;
esac

STATE="$HOME/.cache/orpheus-theme"
RUNTIME="$HOME/.cache/orpheus/config.ron"

# Theme: explicit env  >  remembered (last used)  >  default (solarized-dark).
name="${ORPHEUS_THEME:-$(cat "$STATE" 2>/dev/null || true)}"
name="${name:-solarized-dark}"
theme_path() { if [ "$1" = frost ]; then echo "$DIR/theme.ron"; else echo "$DIR/themes/$1.ron"; fi; }
tf="$(theme_path "$name")"
[ -f "$tf" ] || { name="solarized-dark"; tf="$(theme_path "$name")"; }
[ -f "$tf" ] || { name="frost"; tf="$DIR/theme.ron"; }

# Remember the choice, and stamp it into a runtime config copy so the Config
# tab can show the current theme (keeps the committed config.ron clean).
mkdir -p "$HOME/.cache/orpheus"
printf '%s\n' "$name" > "$STATE"
sed "s/__THEME__/$name/g" "$DIR/config.ron" > "$RUNTIME"

exec rmpc -c "$RUNTIME" -t "$tf" "$@"
